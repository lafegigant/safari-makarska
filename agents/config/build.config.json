{
  "buildConfig": {
    "nodeVersion": "20",
    "packageManager": "npm",
    "buildCommand": "npm run build",
    "testCommand": "npm test",
    "lintCommand": "npm run lint",
    "artifactPath": ".next",
    "timeout": 3600,
    "onFailure": "block-merge"
  },
  "checks": {
    "lint": true,
    "typeCheck": true,
    "test": true,
    "buildSize": {
      "enabled": true,
      "maxSize": "5MB"
    },
    "dependencies": {
      "enabled": true,
      "check": "npm list"
    }
  },
  "notifications": {
    "slack": true,
    "email": false,
    "github": true
  },
  "cache": {
    "enabled": true,
    "paths": ["node_modules", ".next"]
  }
}
